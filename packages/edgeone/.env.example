# 必需：你的 Webflow 项目地址（例如 project-name.webflow.io）
WEBFLOW_ORIGIN_HOST=

# 可选：资源代理路径前缀（默认 /__eo_asset_v3__）
# ASSET_PROXY_PREFIX=/__eo_asset_v3__

# 可选：国内加速 CDN 镜像（不填使用默认值）
# MIRROR_JQUERY=https://lib.baomitu.com/jquery/3.5.1/jquery.min.js
# MIRROR_WEBFONT=https://cdn.jsdelivr.net/npm/webfontloader@1.6.26/webfontloader.js
# MIRROR_JSD_MIRROR=https://cdn.jsdmirror.com
